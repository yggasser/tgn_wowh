{  "version": 3,  "uiGroups": [    { "name": "Районы", "matchRegex": "^(район|районы)\\b", "open": true },    { "name": "Кварталы / микрорайоны", "matchRegex": "^(квартал|микрорайон|мкр\\.?|кв\\.)\\b", "open": false },    { "name": "Дворы", "matchRegex": "^(двор|дворы)\\b", "open": false },    { "name": "Постройки", "matchRegex": ".*", "open": true }  ],  "pointAsPolygon": { "enabled": true, "sizeMeters": 10 },  "panes": { "below": 200, "objects": 400, "above": 650 },  "default": {    "pane": "objects",    "strokeColor": "#3388ff",    "fillColor": "#3388ff",    "weight": 1,    "fillOpacity": 0.10  },  "groupStyles": {    "Районы": { "pane": "below", "strokeColor": "#6aa6ff", "fillColor": "#6aa6ff", "weight": 1, "fillOpacity": 0.05 },    "Кварталы / микрорайоны": { "pane": "below", "strokeColor": "#7bd389", "fillColor": "#7bd389", "weight": 1, "fillOpacity": 0.06 },    "Дворы": { "pane": "objects", "strokeColor": "#ffb020", "fillColor": "#ffb020", "weight": 2, "fillOpacity": 0.08 },    "Постройки": { "pane": "above", "strokeColor": "#3388ff", "fillColor": "#3388ff", "weight": 1, "fillOpacity": 0.12 }  },  "rules": [    { "name": "Трансформаторные будки (чёрные)", "matchAnyCategory": ["трансформаторная будка", "трансформаторные будки"], "pane": "above", "strokeColor": "#111111", "fillColor": "#111111", "weight": 2, "fillOpacity": 0.25 },    { "name": "Скверы (зелёным, под низ)", "matchAnyCategory": ["сквер"], "pane": "below", "strokeColor": "#1f7a1f", "fillColor": "#2ecc71", "weight": 1, "fillOpacity": 0.20 }  ],  "highlight": { "strokeColor": "#ff2d2d", "fillColor": "#ff2d2d", "weight": 4, "fillOpacity": 0.20 },  "zoomFocus": {    "districts": { "enabled": true, "maxZoom": 12, "pane": "below", "strokeColor": "#6aa6ff", "fillColor": "#6aa6ff", "weight": 2, "fillOpacity": 0.08 }  }}